# ============================================================
# Affiliate Bot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# Claude API (get at console.anthropic.com)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Affiliate Tags (from each program's dashboard)
AMAZON_ASSOCIATE_TAG=your-tag-20
HOME_DEPOT_AFFILIATE_TAG=your_hd_tag
WAYFAIR_AFFILIATE_TAG=your_wf_tag

# Buffer (get at buffer.com/developers)
BUFFER_ACCESS_TOKEN=your_buffer_token

# Beehiiv (get at app.beehiiv.com/settings/api)
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxxxx

# GitHub (auto-provided by GitHub Actions — only needed for local runs)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=yourusername/yourusername.github.io
GITHUB_BRANCH=main
